# Copy to backend/.env and fill in your own keys. Never commit the real .env.

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here

# Transcription API key
FIREFLIES_API_KEY=your-transcription-key-here

# Public URL of this backend (needed so the transcription service can
# fetch uploaded audio). Locally: http://localhost:8000
# On Render: https://call-analyser-api.onrender.com
PUBLIC_BASE_URL=http://localhost:8000

# Comma-separated allowed frontend origins, or * for any
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage paths
UPLOAD_DIR=data/uploads
TRANSCRIPT_DIR=data/transcripts
DB_PATH=data/apex.db
